# MySQL (use the database credentials configured in deploy.sh)
MYSQL_HOST=localhost
MYSQL_USER=docgen
MYSQL_PASSWORD=docgen_pass123
MYSQL_DB=login

# Session secret (generate a long random string)
SECRET_KEY=replace_with_long_random_secret_string

# Email (Gmail SMTP for OTP)
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Admin Email (Recipient for notifications/logs if applicable)
ADMIN_EMAIL=admin@example.com

# Server Port
PORT=5000

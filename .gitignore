# ========================
# Secrets & Environment
# ========================
.env
*.env
.env.*
!.env.example

# ========================
# Node.js
# ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================
# Generated Output Files
# (Per-session PDFs / DOCXs — never commit these)
# ========================
output/

# ========================
# Temporary Conversion Files
# (PowerShell scripts, LibreOffice profiles)
# ========================
_tmp_*.ps1
uploads/
/tmp/

# ========================
# Server Logs
# ========================
*.log
logs/
server.out.log
server.err.log

# ========================
# Python Cache
# ========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pyw

# ========================
# OS & Editor Junk
# ========================
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo

# MS Office Temporary & Lock Files
~$*.docx
~$*.doc
~$*.xlsx
~$*.xls
~WR*.tmp
~WRL*.tmp


# ========================
# Lock Files (keep package-lock.json, ignore yarn.lock)
# ========================
yarn.lock

# ========================
# Ignored Project Directories & Python Scripts
# ========================
*.py
unused/
testing/
fonts/
sheet_cache.json
